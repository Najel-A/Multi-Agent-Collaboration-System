# Endpoint configuration for the four NexusTrace inference model agents.
#
# Copy to .env (gitignored) and edit. Any unset *_URL keeps that agent in
# stub mode — useful for partial rollouts and tests.
#
#     cp .env.example .env
#     set -a && source .env && set +a
#     uvicorn app:app --host 0.0.0.0 --port 8001 --reload
#
# ---------------------------------------------------------------------------
# Mac-friendly setup: Ollama on localhost:11434 (this is what runs today)
# ---------------------------------------------------------------------------
# Install + start Ollama:
#     brew install ollama
#     ollama serve &
# Pull the four models (do this once; each takes 1-3 min over decent broadband):
#     ollama pull qwen2.5:7b
#     ollama pull deepseek-r1:7b
#     ollama pull mistral:7b      # stand-in for the 24B executor (24B is too slow on Mac CPU)
#     ollama pull llama3.2:3b
#
# Verify:
#     curl http://localhost:11434/v1/models | python3 -m json.tool

# RCA agent 1 — Qwen 2.5 7B (close base for deveshs18/rca-lora-qwen)
RCA_QWEN_URL=http://localhost:11434
RCA_QWEN_MODEL=qwen2.5:7b

# RCA agent 2 — DeepSeek R1 7B (close base for deveshs18/rca-lora-deepseek)
RCA_DEEPSEEK_URL=http://localhost:11434
RCA_DEEPSEEK_MODEL=deepseek-r1:7b

# Reconciliation / executor — Mistral 7B (smaller stand-in for the 24B image)
EXECUTOR_URL=http://localhost:11434
EXECUTOR_MODEL=mistral:7b

# Validation — Llama 3.2 3B (size-match for mrunalikatta/validator-llama-3b)
VALIDATOR_URL=http://localhost:11434
VALIDATOR_MODEL=llama3.2:3b

# ---------------------------------------------------------------------------
# Tuning
# ---------------------------------------------------------------------------

# Per-call HTTP timeout (seconds). Native ARM Ollama responds in 2-10s for
# 3-7B models; 180s leaves comfortable headroom for cold starts and the
# 7B mistral executor.
MODEL_TIMEOUT_S=180

# ---------------------------------------------------------------------------
# Future: real LoRA images on a remote GPU box
# ---------------------------------------------------------------------------
# When you have GPU access and the LoRA adapter files from
# mrunalikatta/deveshs18, replace the URLs above with the box's IP/port
# and update model_client.py to call /v1/rca/generate with structured
# Kubernetes fields instead of /v1/chat/completions.
